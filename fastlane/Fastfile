# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#     https://docs.fastlane.tools/plugins/available-plugins

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

platform :ios do
  desc "Run tests on the iOS simulator"
  lane :test do
    device = ENV["TEST_DEVICE"] || "iPhone 16"
    run_tests(
      scheme: "Thunderbird",
      workspace: "Thunderbird.xcworkspace",
      destination: "platform=iOS Simulator,name=#{device}",
      code_coverage: true,
      clean: true
    )
  end

  desc "Run swift-format lint check"
  lane :lint do
    sh("cd .. && xcrun swift-format lint . --parallel --recursive --strict")
  end

  desc "Clean build without signing (compilation check)"
  lane :build do
    xcodebuild(
      scheme: "Thunderbird",
      workspace: "Thunderbird.xcworkspace",
      destination: "generic/platform=iOS Simulator",
      build: true,
      clean: true,
      xcargs: "CODE_SIGN_IDENTITY='' CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO"
    )
  end

  desc "Set up App IDs and provisioning profiles via match"
  lane :signing do
    api_key = app_store_connect_api_key(
      key_id: "2PNW542P28",
      issuer_id: "69a6de8c-6b42-47e3-e053-5b8c7c11a4d1",
      key_filepath: File.join(Dir.pwd, "AuthKey_2PNW542P28.p8")
    )
    app_id = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)

    # Register App ID on Developer Portal via ASC API
    token = Spaceship::ConnectAPI::Token.create(**api_key)
    Spaceship::ConnectAPI.token = token
    existing = Spaceship::ConnectAPI::BundleId.find(app_id)
    if existing
      UI.success("App ID '#{app_id}' already exists")
    else
      Spaceship::ConnectAPI::BundleId.create(
        name: "Thunderbird",
        identifier: app_id,
        platform: Spaceship::ConnectAPI::BundleIdPlatform::IOS
      )
      UI.success("Created App ID '#{app_id}'")
    end

    match(type: "development")
    match(type: "appstore")
  end

  desc "Build and run on a connected iOS device"
  lane :device do
    device_name = ENV["DEVICE_NAME"] || "iPhone"
    app_id = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)
    match(type: "development")
    profile_name = ENV["sigh_#{app_id}_development_profile-name"]
    team_id = ENV["sigh_#{app_id}_development_team-id"]

    update_code_signing_settings(
      path: "Thunderbird/Thunderbird.xcodeproj",
      use_automatic_signing: false,
      team_id: team_id,
      bundle_identifier: app_id,
      profile_name: profile_name,
      code_sign_identity: "iPhone Developer"
    )

    xcodebuild(
      scheme: "Thunderbird",
      workspace: "Thunderbird.xcworkspace",
      destination: "platform=iOS,name=#{device_name}",
      build: true,
      xcargs: "PRODUCT_BUNDLE_IDENTIFIER='#{app_id}'"
    )

    # Find the built .app and install on device
    app_path = Dir.glob(File.expand_path("~/Library/Developer/Xcode/DerivedData/Thunderbird-*/Build/Products/Debug-iphoneos/Thunderbird.app")).first
    UI.user_error!("Could not find built Thunderbird.app") unless app_path
    sh("xcrun devicectl device install app --device '#{device_name}' '#{app_path}'")
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    ensure_git_status_clean

    run_tests(
      scheme: "Thunderbird",
      workspace: "Thunderbird.xcworkspace",
      destination: "platform=iOS Simulator,name=#{ENV['TEST_DEVICE'] || 'iPhone 16'}",
      code_coverage: true
    )

    if ENV["VERSION_INPUT"] && !ENV["VERSION_INPUT"].empty?
      puts "Setting version to: #{ENV['VERSION_INPUT']}"
      increment_version_number(
        version_number: ENV["VERSION_INPUT"],
        xcodeproj: "Thunderbird/Thunderbird.xcodeproj"
      )
    end

    build_number = Time.now.utc.strftime("%Y%m%d%H%M")
    increment_build_number(
      build_number: build_number,
      xcodeproj: "Thunderbird/Thunderbird.xcodeproj"
    )

    match(type: "appstore")

    build_app(
      scheme: "Thunderbird",
      workspace: "Thunderbird.xcworkspace",
      export_method: "app-store",
      export_options: {
        uploadBitcode: false,
        uploadSymbols: true,
        compileBitcode: false
      }
    )

    api_key = app_store_connect_api_key(
      key_id: "2PNW542P28",
      issuer_id: "69a6de8c-6b42-47e3-e053-5b8c7c11a4d1",
      key_filepath: File.join(Dir.pwd, "AuthKey_2PNW542P28.p8")
    )
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      distribute_external: ENV["NOTIFY_TESTERS"] == "true",
      notify_external_testers: ENV["NOTIFY_TESTERS"] == "true",
      changelog: "Automated build from GitHub Actions"
    )

    puts "Successfully uploaded to TestFlight!"
  end

  desc "Build for App Store release"
  lane :release do
    ensure_git_status_clean

    run_tests(
      scheme: "Thunderbird",
      workspace: "Thunderbird.xcworkspace",
      destination: "platform=iOS Simulator,name=#{ENV['TEST_DEVICE'] || 'iPhone 16'}",
      code_coverage: true
    )

    if ENV["VERSION_INPUT"] && !ENV["VERSION_INPUT"].empty?
      puts "Setting version to: #{ENV['VERSION_INPUT']}"
      increment_version_number(
        version_number: ENV["VERSION_INPUT"],
        xcodeproj: "Thunderbird/Thunderbird.xcodeproj"
      )
    end

    build_number = Time.now.utc.strftime("%Y%m%d%H%M")
    increment_build_number(
      build_number: build_number,
      xcodeproj: "Thunderbird/Thunderbird.xcodeproj"
    )

    match(type: "appstore")

    build_app(
      scheme: "Thunderbird",
      workspace: "Thunderbird.xcworkspace",
      export_method: "app-store",
      export_options: {
        uploadBitcode: false,
        uploadSymbols: true,
        compileBitcode: false
      }
    )

    api_key = app_store_connect_api_key(
      key_id: "2PNW542P28",
      issuer_id: "69a6de8c-6b42-47e3-e053-5b8c7c11a4d1",
      key_filepath: File.join(Dir.pwd, "AuthKey_2PNW542P28.p8")
    )
    upload_to_app_store(
      api_key: api_key,
      reject_if_possible: true,
      skip_metadata: false,
      skip_screenshots: false,
      submit_for_review: false
    )

    puts "Successfully uploaded to App Store Connect!"
  end
end
